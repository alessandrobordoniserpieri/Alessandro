---
import Layout from '../layouts/Layout.astro';
import heroBg from '../assets/images/hero-background.jpg';
import cardWedding from '../assets/images/card-wedding.jpg';
import cardFuneral from '../assets/images/card-funeral.jpg';
---

<Layout title="Caterina Strings — Wedding & Funeral Music in Manchester">

  <!-- Hero full-screen con immagine -->
  <section
    data-hero
    class="relative min-h-screen flex items-center justify-center"
    style={`background-image: url('${heroBg.src}'); background-size: cover; background-position: center;`}
  >
    <div class="absolute inset-0 bg-black/45"></div>
    <div class="relative z-10 text-center px-6">
      <h1
        class="font-display font-normal leading-tight"
        style="font-size: clamp(3rem, 8vw, 5.5rem); color: #FAF8F4;"
      >
        Caterina Strings
      </h1>
      <p
        class="font-body font-normal text-lg mt-6"
        style="color: #FAF8F4; opacity: 0.82;"
      >
        Live classical music for the moments that matter — Manchester &amp; North West
      </p>
      <button
        type="button"
        data-todo="audio-da-implementare"
        class="listen-btn mt-8 inline-flex items-center gap-2.5 font-body font-medium text-sm"
        style="color: #FAF8F4; border: 1px solid rgba(250, 248, 244, 0.6); padding: 12px 24px; border-radius: 9999px;"
      >
        <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
          <path d="M2 1.5L10 6L2 10.5V1.5Z" />
        </svg>
        Listen to a sample
      </button>
    </div>
  </section>

  <!-- Cards servizi -->
  <section class="max-w-6xl mx-auto px-6 md:px-12 py-24 grid grid-cols-1 md:grid-cols-2 gap-6">

    <!-- Card Wedding -->
    <div class="overflow-hidden">
      <img
        src={cardWedding.src}
        alt="Wedding strings performance"
        class="card-img"
      />
      <div class="p-10" style="background-color: var(--color-bg);">
        <p
          class="font-body font-medium uppercase mb-4"
          style="font-size: 0.75rem; letter-spacing: 0.15em; color: var(--color-wedding);"
        >
          For Your Wedding Day
        </p>
        <h2 class="font-display font-normal text-4xl leading-snug mb-4">
          Make your day unforgettable
        </h2>
        <p class="font-body text-base text-ink mb-8" style="opacity: 0.8;">
          Ceremony, drinks reception, full day packages — string quartet, trio, duo or solo violin.
        </p>
        <a
          href="/weddings"
          class="font-body text-sm font-medium text-wedding inline-flex items-center gap-1 group no-underline"
        >
          Explore weddings
          <span class="inline-block transition-transform duration-150 group-hover:translate-x-1">→</span>
        </a>
      </div>
    </div>

    <!-- Card Funeral -->
    <div class="overflow-hidden">
      <img
        src={cardFuneral.src}
        alt="Funeral strings performance"
        class="card-img"
      />
      <div class="p-10" style="background-color: var(--color-bg);">
        <p
          class="font-body font-medium uppercase mb-4"
          style="font-size: 0.75rem; letter-spacing: 0.15em; color: var(--color-funeral);"
        >
          For a Dignified Farewell
        </p>
        <h2 class="font-display font-normal text-4xl leading-snug mb-4">
          A timeless tribute
        </h2>
        <p class="font-body text-base text-ink mb-8" style="opacity: 0.8;">
          Solo violin, duo or quartet for funeral services across Greater Manchester — same-week availability.
        </p>
        <a
          href="/funerals"
          class="font-body text-sm font-medium text-funeral inline-flex items-center gap-1 group no-underline"
        >
          Explore funerals
          <span class="inline-block transition-transform duration-150 group-hover:translate-x-1">→</span>
        </a>
      </div>
    </div>

  </section>

</Layout>
