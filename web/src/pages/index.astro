---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import heroBg from '../assets/images/hero-background.jpg';
import cardWedding from '../assets/images/card-wedding.jpg';
import cardFuneral from '../assets/images/card-funeral.jpg';
---

<Layout title="Caterina Strings — Wedding & Funeral Music in Manchester">

  <!-- Hero full-screen con immagine -->
  <section
    data-hero
    class="relative min-h-screen flex items-center justify-center"
    style={`background-image: url('${heroBg.src}'); background-size: cover; background-position: center;`}
  >
    <div class="absolute inset-0 bg-black/45"></div>
    <div class="relative z-10 text-center px-6">
      <h1
        class="font-display font-normal leading-tight"
        style="font-size: clamp(3rem, 8vw, 5.5rem); color: #FAF8F4;"
      >
        Caterina Strings
      </h1>
      <p
        class="font-body font-normal text-lg mt-6"
        style="color: #FAF8F4; opacity: 0.82;"
      >
        Live classical music for the moments that matter — Manchester &amp; North West
      </p>
      {/* TODO: wire up audio player */}
      <Button type="button" variant="ghost" class="mt-8">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
          <path d="M2 1.5L10 6L2 10.5V1.5Z" />
        </svg>
        Listen to a sample
      </Button>
    </div>
  </section>

  <!-- Cards servizi — text-first, image revealed on hover (desktop); strip on mobile -->
  <section class="max-w-6xl mx-auto px-6 md:px-12 py-24 grid grid-cols-1 md:grid-cols-2 gap-8">

    <!-- Card Wedding -->
    <a href="/weddings" class="group relative overflow-hidden block no-underline bg-bg-alt">
      <!-- Mobile: image strip always visible -->
      <div class="block md:hidden h-56 overflow-hidden">
        <img
          src={cardWedding.src}
          alt="Wedding strings performance"
          class="w-full h-full object-cover"
        />
      </div>
      <!-- Desktop: hover-reveal image + wine tint -->
      <div
        class="hidden md:block absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
        aria-hidden="true"
      >
        <img
          src={cardWedding.src}
          alt=""
          class="w-full h-full object-cover scale-100 group-hover:scale-[1.04] transition-transform duration-700 ease-out"
        />
        <div class="absolute inset-0" style="background: color-mix(in srgb, var(--color-wedding) 58%, transparent);"></div>
      </div>
      <!-- Text content -->
      <div class="relative z-[1] p-10 md:p-14">
        <p
          class="font-body font-medium uppercase mb-5 text-wedding transition-colors duration-300 group-hover:text-bg"
          style="font-size: 0.7rem; letter-spacing: 0.18em;"
        >
          For Your Wedding Day
        </p>
        <h2
          class="font-display font-normal leading-tight mb-5 text-ink transition-colors duration-300 group-hover:text-bg"
          style="font-size: clamp(2.25rem, 3.5vw, 3.25rem);"
        >
          Make your day<br>unforgettable
        </h2>
        <p class="font-body text-base text-ink/75 mb-10 transition-colors duration-300 group-hover:text-bg">
          Ceremony, drinks reception, full day packages — string quartet, trio, duo or solo violin.
        </p>
        <span
          class="font-body text-sm font-medium inline-flex items-center gap-1 text-wedding transition-colors duration-300 group-hover:text-bg"
        >
          Explore weddings
          <span class="inline-block transition-transform duration-150 group-hover:translate-x-1">→</span>
        </span>
      </div>
    </a>

    <!-- Card Funeral -->
    <a href="/funerals" class="group relative overflow-hidden block no-underline bg-bg-alt">
      <!-- Mobile: image strip always visible -->
      <div class="block md:hidden h-56 overflow-hidden">
        <img
          src={cardFuneral.src}
          alt="Funeral strings performance"
          class="w-full h-full object-cover"
        />
      </div>
      <!-- Desktop: hover-reveal image + slate tint -->
      <div
        class="hidden md:block absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
        aria-hidden="true"
      >
        <img
          src={cardFuneral.src}
          alt=""
          class="w-full h-full object-cover scale-100 group-hover:scale-[1.04] transition-transform duration-700 ease-out"
        />
        <div class="absolute inset-0" style="background: color-mix(in srgb, var(--color-funeral) 68%, transparent);"></div>
      </div>
      <!-- Text content -->
      <div class="relative z-[1] p-10 md:p-14">
        <p
          class="font-body font-medium uppercase mb-5 text-funeral transition-colors duration-300 group-hover:text-bg"
          style="font-size: 0.7rem; letter-spacing: 0.18em;"
        >
          For a Dignified Farewell
        </p>
        <h2
          class="font-display font-normal leading-tight mb-5 text-ink transition-colors duration-300 group-hover:text-bg"
          style="font-size: clamp(2.25rem, 3.5vw, 3.25rem);"
        >
          A timeless<br>tribute
        </h2>
        <p class="font-body text-base text-ink/75 mb-10 transition-colors duration-300 group-hover:text-bg">
          Solo violin, duo or quartet for funeral services across Greater Manchester — same-week availability.
        </p>
        <span
          class="font-body text-sm font-medium inline-flex items-center gap-1 text-funeral transition-colors duration-300 group-hover:text-bg"
        >
          Explore funerals
          <span class="inline-block transition-transform duration-150 group-hover:translate-x-1">→</span>
        </span>
      </div>
    </a>

  </section>

</Layout>
