---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
---

<Layout
  title="Repertoire — Caterina Strings, Manchester"
  description="Our full repertoire — classical, sacred, romantic, pop and folk arrangements. We're happy to learn something specific on request."
>

  <!-- 1. INTRO TIPOGRAFICA -->
  <section data-reveal class="py-32 md:py-40" style="background-color: var(--color-bg);">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="font-body font-medium uppercase mb-6"
        style="font-size: 0.75rem; letter-spacing: 0.15em; color: color-mix(in srgb, var(--color-ink) 60%, transparent);">
        Our Repertoire
      </p>
      <h1 class="font-display font-normal leading-tight mb-8"
        style="font-size: clamp(3rem, 6vw, 5rem);">
        What we can play, on request.
      </h1>
      <p class="font-body mx-auto"
        style="font-size: 1.125rem; line-height: 1.75; max-width: 60ch; color: color-mix(in srgb, var(--color-ink) 80%, transparent);">
        From Baroque processionals to modern pop arrangements, from sacred hymns to film themes.
        Below is a selection of our most-requested pieces. If you'd like something not listed — just ask.
        We're happy to learn a piece that matters to you.
      </p>
    </div>
  </section>

  <!-- 2A. CLASSICAL & BAROQUE -->
  <section data-reveal class="py-20 md:py-24" style="background-color: var(--color-bg);">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <div class="text-center mb-12">
        <p class="font-body font-medium uppercase mb-4"
          style="font-size: 0.75rem; letter-spacing: 0.15em; color: color-mix(in srgb, var(--color-ink) 60%, transparent);">
          Classical &amp; Baroque
        </p>
        <h2 class="font-display font-normal"
          style="font-size: clamp(1.75rem, 3vw, 2.25rem);">
          Timeless music for processionals, ceremonies and receptions
        </h2>
      </div>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-2 max-w-4xl mx-auto list-none p-0">
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Bach — Air on the G String</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Bach — Jesu, Joy of Man's Desiring</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Pachelbel — Canon in D</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Vivaldi — Spring (from The Four Seasons)</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Vivaldi — Winter (Largo)</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Mozart — Eine kleine Nachtmusik</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Handel — Largo (from Xerxes)</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Handel — Hornpipe</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Albinoni — Adagio in G minor</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Massenet — Méditation from Thaïs</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Boccherini — Minuet</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Schubert — Serenade</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Mascagni — Intermezzo from Cavalleria Rusticana</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Elgar — Salut d'Amour</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Elgar — Nimrod (from Enigma Variations)</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Mendelssohn — Wedding March</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Wagner — Bridal Chorus (arrangement)</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Clarke — Trumpet Voluntary</li>
      </ul>
    </div>
  </section>

  <!-- 2B. SACRED & TRADITIONAL -->
  <section data-reveal class="py-20 md:py-24" style="background-color: var(--color-bg-alt);">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <div class="text-center mb-12">
        <p class="font-body font-medium uppercase mb-4"
          style="font-size: 0.75rem; letter-spacing: 0.15em; color: color-mix(in srgb, var(--color-ink) 60%, transparent);">
          Sacred &amp; Traditional
        </p>
        <h2 class="font-display font-normal"
          style="font-size: clamp(1.75rem, 3vw, 2.25rem);">
          Hymns and sacred music for ceremonies and services
        </h2>
      </div>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-2 max-w-4xl mx-auto list-none p-0">
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Schubert — Ave Maria</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Bach / Gounod — Ave Maria</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Fauré — Pavane</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Fauré — Pie Jesu</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Lloyd Webber — Pie Jesu</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">All Things Bright and Beautiful</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Abide With Me</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Amazing Grace</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Jerusalem</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">The Lord's My Shepherd (Crimond)</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">How Great Thou Art</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Be Thou My Vision</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Morning Has Broken</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Make Me a Channel of Your Peace</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Guide Me, O Thou Great Redeemer (Cwm Rhondda)</li>
      </ul>
    </div>
  </section>

  <!-- 2C. ROMANTIC & CINEMATIC -->
  <section data-reveal class="py-20 md:py-24" style="background-color: var(--color-bg);">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <div class="text-center mb-12">
        <p class="font-body font-medium uppercase mb-4"
          style="font-size: 0.75rem; letter-spacing: 0.15em; color: color-mix(in srgb, var(--color-ink) 60%, transparent);">
          Romantic &amp; Cinematic
        </p>
        <h2 class="font-display font-normal"
          style="font-size: clamp(1.75rem, 3vw, 2.25rem);">
          Music from films, classical romantics and modern composers
        </h2>
      </div>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-2 max-w-4xl mx-auto list-none p-0">
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Yiruma — River Flows in You</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Ludovico Einaudi — Nuvole Bianche</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Ludovico Einaudi — Una Mattina</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Joe Hisaishi — Merry-Go-Round of Life (Howl's Moving Castle)</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">John Williams — Hedwig's Theme (Harry Potter)</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">John Williams — Across the Stars (Star Wars)</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">James Horner — My Heart Will Go On (Titanic)</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Henry Mancini — Moon River</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Hans Zimmer — Time (Inception)</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Disney — A Whole New World (Aladdin)</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Disney — Beauty and the Beast</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Disney — Once Upon a Dream (Sleeping Beauty)</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Astor Piazzolla — Libertango</li>
      </ul>
    </div>
  </section>

  <!-- 2D. POP & MODERN -->
  <section data-reveal class="py-20 md:py-24" style="background-color: var(--color-bg-alt);">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <div class="text-center mb-12">
        <p class="font-body font-medium uppercase mb-4"
          style="font-size: 0.75rem; letter-spacing: 0.15em; color: color-mix(in srgb, var(--color-ink) 60%, transparent);">
          Pop &amp; Modern
        </p>
        <h2 class="font-display font-normal"
          style="font-size: clamp(1.75rem, 3vw, 2.25rem);">
          Your favourite songs, arranged for strings
        </h2>
      </div>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-2 max-w-4xl mx-auto list-none p-0">
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Ed Sheeran — Perfect</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Ed Sheeran — Thinking Out Loud</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Coldplay — Yellow</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Coldplay — Fix You</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Ellie Goulding — Love Me Like You Do</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Christina Perri — A Thousand Years</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Adele — Make You Feel My Love</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Adele — Someone Like You</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">The Beatles — Here Comes the Sun</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">The Beatles — Let It Be</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">John Legend — All of Me</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Bruno Mars — Marry You</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Sam Smith — Stay With Me</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Bill Withers — Lovely Day</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Stevie Wonder — Isn't She Lovely</li>
      </ul>
    </div>
  </section>

  <!-- 2E. FOLK & CELTIC -->
  <section data-reveal class="py-20 md:py-24" style="background-color: var(--color-bg);">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <div class="text-center mb-12">
        <p class="font-body font-medium uppercase mb-4"
          style="font-size: 0.75rem; letter-spacing: 0.15em; color: color-mix(in srgb, var(--color-ink) 60%, transparent);">
          Folk &amp; Celtic
        </p>
        <h2 class="font-display font-normal"
          style="font-size: clamp(1.75rem, 3vw, 2.25rem);">
          Traditional pieces from across the British Isles
        </h2>
      </div>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-2 max-w-4xl mx-auto list-none p-0">
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">The Skye Boat Song</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Danny Boy</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Greensleeves</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Scarborough Fair</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">The Water Is Wide</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">She Moved Through the Fair</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Loch Lomond</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">The Parting Glass</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Carrickfergus</li>
        <li class="font-body" style="font-size: 0.9375rem; line-height: 1.6; color: color-mix(in srgb, var(--color-ink) 78%, transparent);">Wild Mountain Thyme</li>
      </ul>
    </div>
  </section>

  <!-- 3. FINAL CTA -->
  <section data-reveal class="py-24 md:py-32" style="background-color: var(--color-bg-alt);">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display font-normal mb-6"
        style="font-size: clamp(2rem, 3.5vw, 2.5rem);">
        Looking for something specific?
      </h2>
      <p class="font-body mx-auto mb-10"
        style="font-size: 1.0625rem; line-height: 1.75; max-width: 52ch; color: color-mix(in srgb, var(--color-ink) 72%, transparent);">
        We're happy to learn a piece that matters to you. Get in touch and tell us what you have in mind.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/contact" variant="primary">Get in touch</Button>
        <a href="/weddings" class="font-body text-sm font-medium no-underline transition-colors duration-150"
          style="color: color-mix(in srgb, var(--color-ink) 65%, transparent);">
          Browse wedding packages →
        </a>
      </div>
    </div>
  </section>

</Layout>
