---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact — Caterina Strings"
  description="Get in touch about wedding or funeral music in Manchester and the North West."
>

  <!-- Hero compatto -->
  <section class="pt-32 pb-16 text-center">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <p
        class="font-body font-medium uppercase mb-5"
        style="font-size: 0.75rem; letter-spacing: 0.15em; color: color-mix(in srgb, var(--color-ink) 55%, transparent);"
      >
        Contact
      </p>
      <h1
        class="font-display font-normal mb-6"
        style="font-size: clamp(2.5rem, 5vw, 3rem);"
      >
        Get in touch
      </h1>
      <p
        class="font-body mx-auto"
        style="font-size: 1rem; line-height: 1.72; max-width: 50ch; color: color-mix(in srgb, var(--color-ink) 68%, transparent);"
      >
        We respond within four hours on business days. Please let us know the date, location, and which service we'd be playing for — it helps us give you a precise quote quickly.
      </p>
    </div>
  </section>

  <!-- Contact methods -->
  <section data-reveal class="pb-20 md:pb-28">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Email -->
        <div class="p-8" style="border: 1px solid var(--color-rule);">
          <h2 class="font-display font-normal mb-5" style="font-size: 1.5rem;">Email</h2>
          <a
            href="mailto:hello@caterinastrings.co.uk"
            class="font-body text-sm text-ink no-underline hover:text-wedding transition-colors duration-150 block mb-3"
          >
            hello@caterinastrings.co.uk
          </a>
          <p class="font-body text-sm" style="color: color-mix(in srgb, var(--color-ink) 58%, transparent);">
            Best for detailed enquiries
          </p>
        </div>

        <!-- Phone -->
        <div class="p-8" style="border: 1px solid var(--color-rule);">
          <h2 class="font-display font-normal mb-5" style="font-size: 1.5rem;">Phone</h2>
          <a
            href="tel:+440000000000"
            class="font-body text-sm text-ink no-underline hover:text-wedding transition-colors duration-150 block mb-3"
          >
            +44 (0)000 000 0000
          </a>
          <p class="font-body text-sm" style="color: color-mix(in srgb, var(--color-ink) 58%, transparent);">
            Mon–Sat, 9am–7pm
          </p>
        </div>

        <!-- WhatsApp -->
        <div class="p-8" style="border: 1px solid var(--color-rule);">
          <h2 class="font-display font-normal mb-5" style="font-size: 1.5rem;">WhatsApp</h2>
          <a
            href="https://wa.me/440000000000"
            class="font-body text-sm text-ink no-underline hover:text-wedding transition-colors duration-150 block mb-3"
          >
            +44 (0)000 000 0000
          </a>
          <p class="font-body text-sm" style="color: color-mix(in srgb, var(--color-ink) 58%, transparent);">
            For quick questions
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Bottom note -->
  <div class="pb-20 text-center">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <p
        class="font-body"
        style="font-size: 0.9375rem; color: color-mix(in srgb, var(--color-ink) 65%, transparent);"
      >
        A booking form is coming soon. In the meantime, please use any of the methods above.
      </p>
    </div>
  </div>

</Layout>
