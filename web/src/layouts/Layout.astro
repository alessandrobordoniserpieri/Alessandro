---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Caterina Strings",
  description = "",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <noscript><style>[data-reveal] { opacity: 1; transform: none; }</style></noscript>
  </head>
  <body class="bg-bg text-ink font-body min-h-screen flex flex-col">
    <header id="site-header" class="fixed top-0 left-0 right-0 z-50 px-8 py-5 flex items-center justify-between border-b border-transparent">
      <a href="/" class="font-display text-2xl tracking-wide no-underline">
        Caterina Strings
      </a>
      <nav>
        <a href="/contact" class="font-body text-sm font-medium">
          Contact
        </a>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-rule">
      <div class="max-w-6xl mx-auto px-6 md:px-12 py-12 md:py-16 grid grid-cols-1 md:grid-cols-3 gap-12">

        <!-- Brand -->
        <div>
          <p class="font-display text-2xl tracking-wide mb-3">Caterina Strings</p>
          <p class="font-body text-sm" style="color: color-mix(in srgb, var(--color-ink) 65%, transparent);">
            Live classical music for the moments that matter
          </p>
          <p class="font-body text-sm mt-1" style="color: color-mix(in srgb, var(--color-ink) 65%, transparent);">
            Manchester &amp; North West
          </p>
        </div>

        <!-- Explore -->
        <div>
          <p class="font-body font-medium uppercase mb-4" style="font-size: 0.75rem; letter-spacing: 0.15em; color: color-mix(in srgb, var(--color-ink) 60%, transparent);">
            Explore
          </p>
          <nav class="flex flex-col gap-2">
            <a href="/weddings" class="font-body text-sm text-ink no-underline hover:text-wedding transition-colors duration-150">Weddings</a>
            <a href="/funerals" class="font-body text-sm text-ink no-underline hover:text-funeral transition-colors duration-150">Funerals</a>
            <a href="/contact" class="font-body text-sm text-ink no-underline hover:text-wedding transition-colors duration-150">Contact</a>
          </nav>
        </div>

        <!-- Get in touch -->
        <div>
          <p class="font-body font-medium uppercase mb-4" style="font-size: 0.75rem; letter-spacing: 0.15em; color: color-mix(in srgb, var(--color-ink) 60%, transparent);">
            Get in Touch
          </p>
          <p class="font-body text-sm text-ink mb-1">hello@caterinastrings.co.uk</p>
          <p class="font-body text-sm text-ink mb-4">+44 (0)000 000 0000</p>
          <a href="/contact" class="font-body text-sm font-medium text-wedding inline-flex items-center gap-1 group no-underline">
            Request a quote
            <span class="inline-block transition-transform duration-150 group-hover:translate-x-1">→</span>
          </a>
        </div>

      </div>

      <!-- Bottom bar -->
      <div class="border-t border-rule">
        <div class="max-w-6xl mx-auto px-6 md:px-12 py-4 text-center">
          <p class="font-body" style="font-size: 0.75rem; color: color-mix(in srgb, var(--color-ink) 50%, transparent);">
            © 2026 Caterina Strings · All rights reserved
          </p>
        </div>
      </div>
    </footer>

    <script>
      const header = document.getElementById('site-header');
      function tick() {
        const hero = document.querySelector('[data-hero]');
        if (!header) return;
        const pastHero = hero ? hero.getBoundingClientRect().bottom <= 0 : true;
        header.classList.toggle('scrolled', pastHero);
      }
      window.addEventListener('scroll', tick, { passive: true });
      tick();
    </script>

    <script>
      const ro = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('visible'); ro.unobserve(e.target); }
        });
      }, { threshold: 0.08 });
      document.querySelectorAll('[data-reveal]').forEach(el => ro.observe(el));
    </script>
  </body>
</html>
