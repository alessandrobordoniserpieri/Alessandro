{
  "worktree": {
    "bgIsolation": "none"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(rm -rf*)",
      "Bash(rm -r*)",
      "Bash(Remove-Item -Recurse*)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D*)",
      "Bash(git checkout --orphan*)",
      "Bash(git filter-branch*)",
      "Bash(git update-ref -d*)"
    ]
  }
}
